      <parameter error="0.04" free="1" max="5" min="0" name="alpha" scale="1" value="2.1"/>
      <parameter error="0.2" free="1" max="10" min="0" name="beta" scale="0.1" value="1.2"/>
      <parameter free="0" max="100" min="0.1" name="Eb" scale="1000" value="1.0"/>
    </spectrum>
    <spatialModel file="$(LATEXTDIR)/Templates/CygnusLoop_GALEX.fits" map_based_integral="true" type="SpatialMap">
      <parameter free="0" max="1" min="1" name="Prefactor" scale="1" value="1"/>
    </spatialModel>
  </source>
